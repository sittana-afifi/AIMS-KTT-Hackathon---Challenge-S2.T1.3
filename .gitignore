# --- Python Internals ---
# To prevent temporary cache files from cluttering the repo
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Environments ---
# Local library files
venv/
.env/
env/
bin/
lib/
develop-eggs/
dist/
eggs/
lib64/
parts/
sdist/
var/
*.egg-info/

# --- Large Data & Models ---
# Files > 100MB will be hosted on Hugging Face/Drive
*.csv
*.json
*.parquet
*.sql
*.sqlite

# Model weights will be hosted on Hugging Face
*.bin
*.safetensors
*.gguf
*.pth
*.h5
*.ckpt

# --- System & IDE Files ---
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# --- LLM Logs ---
# Will keep our raw API logs local
.python_history
